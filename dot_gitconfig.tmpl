[user]
	name = {{ .git.user.name }}
	email = {{ .git.user.email }}
	signingkey = {{ .git.user.signingkey }}

[core]
  pager = delta --color-only
  autocrlf = input

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true    # use n and N to move between diff sections
  line-numbers = true
  side-by-side = true
  hyperlinks = true
  hyperlinks-file-link-format = "idea://open?file={path}&line={line}"
  features = unobtrusive-line-numbers decorations
  whitespace-error-style = 22 reverse
  map-styles = bold purple => syntax magenta, bold cyan => syntax blue

[delta "unobtrusive-line-numbers"]
  line-numbers = true
  line-numbers-minus-style = "#444444"
  line-numbers-zero-style = "#444444"
  line-numbers-plus-style = "#444444"
  line-numbers-left-format = "{nm:>4}┊"
  line-numbers-right-format = "{np:>4}│"
  line-numbers-left-style = blue
  line-numbers-right-style = blue

[delta "decorations"]
  commit-decoration-style = bold yellow box ul
  file-style = bold yellow ul
  file-decoration-style = none
  hunk-header-decoration-style = yellow box

{{ if eq .chezmoi.os "darwin" }}
[merge]
  tool = intellij
[mergetool "intellij"]
  cmd = '/Applications/IntelliJ IDEA.app/Contents/macOS/idea' merge "$LOCAL" "$REMOTE" "$BASE" "$MERGED"
  trustExitCode = true
[mergetool]
  keepBackup = false
{{ end }}

[diff]
  colorMoved = default

[commit]
	gpgsign = true
[gpg]
	format = ssh
{{- if eq .chezmoi.os "darwin" }}
{{- $ghPlatform := get .git.github.credential_helper "darwin" | default dict }}
{{- $ghBinary := get $ghPlatform .chezmoi.arch | default (get $ghPlatform "default") }}
{{- if $ghBinary }}
{{- $ghCredentialHelper := printf "!%s auth git-credential" $ghBinary }}
[credential "https://github.com"]
	helper =
	helper = {{ $ghCredentialHelper }}
[credential "https://gist.github.com"]
	helper =
	helper = {{ $ghCredentialHelper }}
{{- end }}
{{- else if eq .chezmoi.os "linux" }}
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
{{- end }}
