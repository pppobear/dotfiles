<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "https://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.enoch.rbw-ssh-auth-sock</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-lc</string>
    <string>exec "$HOME/.local/bin/rbw-sync-ssh-auth-sock"</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>StandardOutPath</key>
  <string>/tmp/com.enoch.rbw-ssh-auth-sock.out.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/com.enoch.rbw-ssh-auth-sock.err.log</string>
</dict>
</plist>
