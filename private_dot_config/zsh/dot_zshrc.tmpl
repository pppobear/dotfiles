#!/usr/bin/env zsh
# ~/.config/zsh/.zshrc
# This file is sourced in interactive shells
# Generated by chezmoi - DO NOT EDIT MANUALLY

# Load core environment variables
source "$ZDOTDIR/core/environment.zsh"

# Load Zsh options and settings
source "$ZDOTDIR/core/options.zsh"

# Load core functions
source "$ZDOTDIR/core/functions.zsh"

# Load oh-my-zsh
source "$ZDOTDIR/core/omz.zsh"

# Load core aliases (after oh-my-zsh to avoid being overridden)
source "$ZDOTDIR/core/aliases.zsh"

source "$ZDOTDIR/.p10k.zsh"

# Load platform-specific configuration
{{- if eq .chezmoi.os "darwin" }}
[ -f "$ZDOTDIR/platform/macos.zsh" ] && source "$ZDOTDIR/platform/macos.zsh"
{{- else if eq .chezmoi.os "linux" }}
[ -f "$ZDOTDIR/platform/linux.zsh" ] && source "$ZDOTDIR/platform/linux.zsh"
{{- end }}

# Load tool integrations
for tool_config in "$ZDOTDIR"/tools/*.zsh; do
  [ -f "$tool_config" ] && source "$tool_config"
done

# Load plugin manager
[ -f "$ZDOTDIR/plugins/manager.zsh" ] && source "$ZDOTDIR/plugins/manager.zsh"

# Load plugins
[ -f "$ZDOTDIR/plugins/zsh-plugins.zsh" ] && source "$ZDOTDIR/plugins/zsh-plugins.zsh"

# Load user configuration (should be last)
[ -f "$ZDOTDIR/local/user.zsh" ] && source "$ZDOTDIR/local/user.zsh"

# Restore Ghostty identity after all integrations have loaded. Some tools or
# wrappers inside tmux reset TERM_PROGRAM to "tmux", which breaks notification
# feature detection for terminal-aware CLIs.
if [[ -n "${GHOSTTY_RESOURCES_DIR:-}" || "${TERM:-}" == "xterm-ghostty" || "${LC_TERMINAL:-}" == "ghostty" ]]; then
  export LC_TERMINAL="ghostty"
  export TERM_PROGRAM="ghostty"
fi
