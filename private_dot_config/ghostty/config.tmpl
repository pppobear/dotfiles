# ============================================================
# Theme
# ============================================================

theme = {{ if eq .chezmoi.hostname "dabai-arch" }}noctalia{{ else }}Gruvbox Light{{ end }}
window-theme = light

# ============================================================
# Font Settings
# ============================================================

font-family = Maple Mono NF CN
font-size = 13
font-thicken = true
adjust-cell-height = 1

# ============================================================
# Window Settings
# ============================================================

macos-option-as-alt = true
macos-titlebar-style = hidden

window-padding-x = 14
window-padding-y = 12,10
window-padding-balance = true
window-padding-color = extend
window-save-state = always
window-colorspace = display-p3
resize-overlay = after-first

# ============================================================
# Shell Integration
# ============================================================

term = xterm-256color
shell-integration = detect
shell-integration-features = cursor,sudo,title,path

# ============================================================
# Cursor Settings
# ============================================================

cursor-style = block
cursor-style-blink = true
cursor-click-to-move = true

# ============================================================
# Scrollback & Mouse
# ============================================================

scrollback-limit = 20000
link-url = true
mouse-scroll-multiplier = 5
mouse-hide-while-typing = true

# ============================================================
# Clipboard Settings
# ============================================================

clipboard-read = ask
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
copy-on-select = clipboard
selection-clear-on-copy = true

# ============================================================
# Appearance
# ============================================================

background-opacity = 0.9
background-blur-radius = 24
minimum-contrast = 1.1
unfocused-split-opacity = 0.92
confirm-close-surface = true

# ============================================================
# Keyboard Bindings
# ============================================================

# ----- Clipboard -----
keybind = shift+insert=paste_from_selection

# ----- Scrolling -----
keybind = ctrl+shift+k=scroll_page_lines:-1
keybind = ctrl+shift+j=scroll_page_lines:1
keybind = ctrl+shift+up=scroll_page_lines:-1
keybind = ctrl+shift+down=scroll_page_lines:1
keybind = ctrl+shift+page_up=scroll_page_up
keybind = ctrl+shift+page_down=scroll_page_down
keybind = ctrl+shift+home=scroll_to_top
keybind = ctrl+shift+end=scroll_to_bottom

# ----- Window Management -----
keybind = ctrl+shift+enter=new_window

# ----- Mouse / Links -----
keybind = super+shift+m=toggle_mouse_reporting

# ----- Split Navigation -----
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right

# ----- Split Resize -----
keybind = super+ctrl+h=resize_split:left,10
keybind = super+ctrl+j=resize_split:down,10
keybind = super+ctrl+k=resize_split:up,10
keybind = super+ctrl+l=resize_split:right,10

# ----- Font Size -----
keybind = ctrl+shift+plus=increase_font_size:1
keybind = ctrl+shift+equal=increase_font_size:1
keybind = ctrl+shift+minus=decrease_font_size:1
keybind = ctrl+shift+zero=reset_font_size

# ----- Quick Terminal (Global Hotkey) -----
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# ============================================================
# Quick Terminal Settings
# ============================================================

quick-terminal-position = top
quick-terminal-animation-duration = 0.15
quick-terminal-autohide = true
quick-terminal-space-behavior = move
